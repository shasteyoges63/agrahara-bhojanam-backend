PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=agrahara_bhojanam

# Gmail SMTP — use App Password (not normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
# Quote if password has spaces: SMTP_PASS="abcd efgh ijkl mnop"
SMTP_PASS=your16charapppassword
SMTP_FROM=your@gmail.com

# Store notification — new order emails sent here (defaults to SMTP_FROM)
# SMTP_NOTIFY_TO=admin@agraharabhojanam.com

# Alternative: port 587 with STARTTLS
# SMTP_PORT=587
# SMTP_SECURE=false
